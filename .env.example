# Paste the full Spotify album URL here
ALBUM_URL=https://open.spotify.com/album/6ZwFhP5dXFACM5dFbopPvD

# Optional: override artist ID (auto-detected from album if blank)
ARTIST_ID=6EewwDHdBVYpE65rUV5taC

# Spotify for Artists session cookie — required for live sub-1k stream counts
# 1. Log into https://artists.spotify.com in Chrome
# 2. DevTools → Application → Cookies → artists.spotify.com
# 3. Copy the value of `sp_dc` and paste below (keep it secret)
SP_DC=

# How often to poll for updated play counts (seconds). Use 30-60 with S4A.
POLL_INTERVAL_SECONDS=60

# Optional: dashboard title override
DASHBOARD_TITLE=
